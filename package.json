{
  "name": "@reactzero/datepicker",
  "version": "0.1.1",
  "description": "Zero-dependency, accessible React date/time picker. WCAG 2.1 AA, four variants, <12 kB gzipped.",
  "keywords": [
    "react",
    "datepicker",
    "date-picker",
    "timepicker",
    "date-range",
    "time-picker",
    "accessible",
    "a11y",
    "wcag",
    "zero-dependencies",
    "headless",
    "css-variables",
    "themes",
    "i18n",
    "intl",
    "typescript"
  ],
  "license": "MIT",
  "author": {
    "name": "Luis Vargas",
    "email": "lvargasdesign@gmail.com",
    "url": "https://github.com/motiondesignlv"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/motiondesignlv/reactzero-datepicker"
  },
  "homepage": "https://motiondesignlv.github.io/reactzero-datepicker",
  "bugs": {
    "url": "https://github.com/motiondesignlv/reactzero-datepicker/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/motiondesignlv"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "npm run storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "vite build && tsc -p tsconfig.build.json",
    "postbuild": "node -e \"const fs=require('fs');const css=fs.readFileSync('dist/style.css','utf8');if(css.includes('@import')){console.error('ERROR: CSS still contains @import');process.exit(1);}const js=fs.readFileSync('dist/index.js','utf8');console.log('Build OK — JS:',Math.round(js.length/1024)+'kB, CSS:',Math.round(css.length/1024)+'kB');\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/__tests__/utils src/__tests__/hooks",
    "test:components": "vitest run src/__tests__/components",
    "test:a11y": "vitest run src/__tests__/a11y",
    "test:all": "vitest run --coverage && vitest run src/__tests__/a11y",
    "ci": "npm run typecheck && npm run lint && npm run test:all",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "prepublishOnly": "npm run ci && npm run build",
    "chromatic": "npx chromatic --project-token=***REMOVED***"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/blocks": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@storybook/test": "8.6.18",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest-axe": "^3.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.4.27",
    "chromatic": "^15.2.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "full-icu": "^1.5.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.8",
    "size-limit": "^11.2.0",
    "storybook": "8.6.18",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.5.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "10 kB"
    },
    {
      "path": "dist/style.css",
      "limit": "5 kB"
    }
  ]
}
